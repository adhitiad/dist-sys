# ============================================================
# DISTRIBUTOR SYSTEM — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# ---- App -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Distributor System"
NODE_ENV=development

# ---- Database MongoDB ------------------------------------------
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/distributor?retryWrites=true&w=majority"

# ---- Better Auth -----------------------------------------------
BETTER_AUTH_SECRET=ganti-dengan-string-acak-minimal-32-karakter
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — buat di console.cloud.google.com
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx

# ---- Cloudinary Storage ----------------------------------------
# Ambil dari: cloudinary.com → Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=nama-cloud-anda
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=rahasia-api-anda

# Folder root di Cloudinary (semua aset masuk ke sini)
CLOUDINARY_FOLDER=distributor

# Untuk komponen upload di browser (buat Upload Preset di Cloudinary
# Dashboard → Settings → Upload → Add upload preset → Mode: Unsigned)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=nama-cloud-anda
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=distributor-unsigned

# ---- Email (Resend) --------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM="Distributor <noreply@domain.com>"

# ---- Midtrans Payment Gateway ----------------------------------
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx

# ---- Rajaongkir (Ongkos Kirim) ---------------------------------
RAJAONGKIR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Logging ---------------------------------------------------
LOG_LEVEL=debug
